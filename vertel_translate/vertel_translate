#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Vertel translation automation script - SKAPAR PO-filer automatiskt!
"""

import os
import subprocess
import glob
import time
from pathlib import Path
import polib

print("🚀 Skriptet startar...")

# ÖVERST i skriptet (efter imports):
GIT_USER = os.environ.get('SUDO_USER', os.getlogin())
print(f"👤 Git-user: {GIT_USER} (SSH-nyckel auto-autentiserar)")

if os.geteuid() != 0:
    print("❌ SKRIPTET KräVER ROOT-RÄTTIGHETER!")
    print("💡 Kör: sudo ./vertel_translate")
    raise SystemExit(1)

def update_sv_po_git(module_path, project_name):
    print(f"  🌐 sudo -u {GIT_USER} git fetch origin...")
    fetch_result = subprocess.run(
        ['sudo', '-u', GIT_USER, 'git', 'fetch', 'origin'], 
        capture_output=True, text=True, timeout=20
    )

    """Uppdaterar sv.po från git - med MAXIMAL VISUALISERING!"""
    print(f"  🌐 GIT-CHECK: {project_name}/{module_path.name}")
    
    sv_po_path = module_path / 'i18n' / 'sv.po'
    
    # Skippa om ingen sv.po eller inte git-repo
    if not sv_po_path.exists():
        print(f"  ⏭️  Skippar GIT: Ingen sv.po finns")
        return False
    
    if not (module_path / '.git').exists():
        print(f"  ⏭️  Skippar GIT: Inte git-repo")
        return False
    
    original_cwd = os.getcwd()
    print(f"  🏠 Start-cwd: {Path(original_cwd).name}")
    
    try:
        print(f"  📂 STEG 1: cd {module_path.name}")
        os.chdir(str(module_path))
        print(f"  ✅ cwd= {os.getcwd().split('/')[-1]}")
        
        print(f"  🌐 STEG 2: git fetch origin...")
        fetch_result = subprocess.run(
            ['git', 'fetch', 'origin'], 
            capture_output=True, text=True, timeout=20
        )
        print(f"  ✅ git fetch: returncode={fetch_result.returncode}")
        
        print(f"  🌐 STEG 3: git checkout origin/main -- i18n/sv.po")
        checkout_result = subprocess.run(
            ['git', 'checkout', 'origin/main', '--', 'i18n/sv.po'],
            capture_output=True, text=True, timeout=10
        )
        print(f"  📄 git checkout: returncode={checkout_result.returncode}")
        if checkout_result.returncode != 0:
            print(f"  ⚠️  git stderr: {checkout_result.stderr.strip()}")
        
        print(f"  🏠 STEG 4: cd tillbaka till {VERTEL_DIR.name}")
        os.chdir(VERTEL_DIR)
        print(f"  ✅ cwd= {VERTEL_DIR.name}")
        
        # KOLLA RESULTAT
        if sv_po_path.exists():
            size_kb = sv_po_path.stat().st_size / 1024
            size_change = "NY/UPPDATERAD" if size_kb > 0 else "TOM"
            print(f"  🎉 GIT-OK: {project_name}-{module_path.name}.po ({size_kb:.1f}KB {size_change})")
            return True
        else:
            print(f"  ❌ GIT: sv.po försvann!?")
            return False
            
    except subprocess.TimeoutExpired:
        print(f"  ⏰ GIT TIMEOUT!")
        os.chdir(VERTEL_DIR)
        return False
    except Exception as e:
        print(f"  💥 GIT-FEL: {e}")
        try:
            os.chdir(VERTEL_DIR)
        except:
            pass
        return False

def has_untranslated_entries(po_path):
    """Returnerar True OM det finns tomma/översättningsbehövande entries"""
    try:
        po = polib.pofile(str(po_path))
        untranslated_count = 0
        fuzzy_count = 0
        
        for entry in po:
            if entry.msgstr.strip() == "":
                untranslated_count += 1
            if entry.obsolete:
                fuzzy_count += 1
        
        total_needs_work = untranslated_count + fuzzy_count
        print(f"  🔍 {po_path.name}: {untranslated_count} tomma, {fuzzy_count} fuzzy")
        return total_needs_work > 0
    except Exception as e:
        print(f"  ⚠️ Kunde inte läsa PO: {e}")
        return True

# KONFIGURATION
VERTEL_DIR = Path("/usr/share/vertel-translate")
BASE_PATH = "/usr/share"
PROJECT_PATTERN = os.path.join(BASE_PATH, "odoo-*")

LOG_FILES = {
    "summary": "project_summary.log",
    "new": "new_translations.log"
}

print(f"🚀 Startar Vertel Translator i {VERTEL_DIR}")

# SKAPA loggar (BARA de vi behöver)
for f in LOG_FILES.values():
    log_path = VERTEL_DIR / f
    if log_path.exists():
        log_path.unlink()
    log_path.touch()
    print(f"📝 Logg OK: {log_path.name}")

# ÖPPNA loggar med flush!
log_summary = open(VERTEL_DIR / LOG_FILES["summary"], "a")
log_new = open(VERTEL_DIR / LOG_FILES["new"], "a")

# Rensa gamla PO-filer
for f in VERTEL_DIR.glob("*.po"):
    f.unlink(missing_ok=True)

# HUVUDLOOP
for project_path_str in glob.glob(PROJECT_PATTERN):
    project_path = Path(project_path_str)
    project_name = project_path.name
    print(f"\n--- 📦 Project: {project_name} ---")
    
    modules = []
    for item in project_path.iterdir():
        if item.is_dir() and (item / "__manifest__.py").exists():
            modules.append(item.name)
    
    if not modules:
        print(f"  ℹ️ Inga moduler i {project_name}")
        continue
    
    project_ok = 0
    project_fails = 0
    project_times = []
    
    # ✅ RÄTT INDENT — 4 mellanslag!
    for module_name in modules:
        module_path = project_path / module_name

        if 'oca' in module_name.lower():
            print(f"  ⏭️  SKIPPAR OCA: {module_name}")
            project_ok += 1
            continue

        start_time = time.time()
        update_sv_po_git(module_path, project_name)
        print(f"  🧪 {module_name} (cwd={module_path})...")
        
        cmd = [
            'bash', '/usr/local/bin/checkmodule',
            '-d', 'vertel_translate',
            '-m', f'base,{module_name}',
            '-e', '-L', 'sv', '--drop'
        ]
        
        try:
            result = subprocess.run(cmd, cwd=module_path, capture_output=True, text=True, timeout=60)
            elapsed = time.time() - start_time
            
            source_po = module_path / 'i18n' / 'sv.po'
            
            if not source_po.exists():
                failed_modules_log = VERTEL_DIR / "failed_modules.log"
                error_info = f"{project_name}/{module_name}: Ingen sv.po SKAPAD (returncode={result.returncode})"
                with open(failed_modules_log, "a") as f:
                    f.write(f"{error_info}\n")
                print(f"  ⚠️ {module_name}: Inga översättn.strängar → Loggat")
                project_fails += 1
            else:
                size_kb = source_po.stat().st_size / 1024
                target_po = VERTEL_DIR / f"{project_name}-{module_name}.po"
                target_po.write_bytes(source_po.read_bytes())
                
                print(f"  ⏱️ {module_name}: {elapsed:.1f}s ({size_kb:.1f}KB)")
                project_times.append(elapsed)

                if result.returncode != 0:
                    print(f"  ❌ checkmodule fel: {result.stderr.strip()}")
                
                if has_untranslated_entries(target_po):
                    print(f"  📄 {project_name}-{module_name}.po BEHÖVER ÖVERSÄTTNING!")
                    project_fails += 1
                    log_new.write(f"{project_name}/{module_name}: BEHÖVER ÖVERSÄTTNING\n")
                    log_new.flush()
                else:
                    print(f"  🗑️ {project_name}-{module_name}.po FULLT ÖVERSÄTTAD!")
                    target_po.unlink()
                    project_ok += 1

        except subprocess.TimeoutExpired:
            print(f"  ⏰ {module_name}: TIMEOUT!")
            project_fails += 1
        except Exception as e:
            print(f"  ❌ {module_name}: {e}")
            project_fails += 1
    
    # SAMMANFATTNING - NU RÄTT PLATS!
    avg_time = sum(project_times) / len(project_times) if project_times else 0.0
    summary_line = f"{project_name}: {project_ok}/{len(modules)} OK, {project_fails} FAILS\n"
    print(f"📊 {project_name}: {project_ok}/{len(modules)} OK, {project_fails} FAILS, avg {avg_time:.1f}s")
    log_summary.write(summary_line)
    log_summary.flush()

# Stäng loggar
log_summary.close()
log_new.close()

print(f"\n🎉 KLART! Kolla PO-filer i {VERTEL_DIR}")
print("📄 poedit *.po  # Översätt röda!")
print(f"📊 Kolla project_summary.log för fullständig översikt!")
